MCP_SERVER_NAME=media-mcp-server
MCP_PORT=3333
MCP_AUTH_TOKEN=your_secret_token_here
MEDIA_OUTPUT_DIR=outputs
MCP_TOOL_SETTINGS_PATH=.media-mcp-tools.json
MCP_API_KEYS_PATH=.media-mcp-api-keys.json
# Optional comma-separated allowlist. When set, UI tool exposure editing is locked.
# MCP_EXPOSED_TOOLS=list_media_providers,generate_image_google_gemini_3_1_flash_image_preview
# Optional comma-separated denylist applied after UI/env allowlist.
# MCP_DISABLED_TOOLS=check_apimart_balance

# ApiMart image/video/audio generation
APIMART_API_KEY=
APIMART_BASE_URL=https://api.apimart.ai/v1

# Google Gemini / GenAI official SDK provider
# GOOGLE_API_KEY is preferred; GEMINI_API_KEY is also accepted by this server.
# For multiple keys (comma-separated), use GOOGLE_API_KEYS which locks UI editing.
# GOOGLE_API_KEYS=AIzaSyA1...,AIzaSyB2...
GOOGLE_API_KEY=
GOOGLE_IMAGE_MODEL=gemini-3.1-flash-image-preview
GOOGLE_VIDEO_MODEL=veo-3.1-generate-preview
GOOGLE_TTS_MODEL=gemini-3.1-flash-tts-preview
GOOGLE_TTS_VOICE=Kore
